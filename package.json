{
  "name": "runcycles",
  "version": "0.1.0",
  "description": "TypeScript client for the Cycles budget-management protocol",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "run": "^1.5.0"
  }
}
